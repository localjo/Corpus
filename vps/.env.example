# Optional webhook for failure notifications
NOTIFY_WEBHOOK_URL=

# Git defaults
DEFAULT_BRANCH=main
COMMIT_MESSAGE_PREFIX=sync

# Optional git identity for cron commits (quote if spaces)
GIT_AUTHOR_NAME="Corpus Bot"
GIT_AUTHOR_EMAIL=corpus-bot@example.com

# One-shot bypass Syncthing temp/conflict prechecks only (manual recovery)
# CORPUS_SYNC_FORCE=1

# Disable Syncthing temp/conflict skip checks only (avoid for Syncthing vaults)
# CORPUS_SKIP_SYNC_LOCK_CHECKS=1

# Optional: pause Syncthing peer connections during git (no folder IDs). Requires API key.
# SERIAL flock so two vault cron runs cannot overlap pause/resume on one daemon.
# SYNCTHING_PAUSE_FOR_GIT=1
# SYNCTHING_API_URL=http://127.0.0.1:8384
# SYNCTHING_API_KEY=
# CORPUS_SYNCTHING_PAUSE_SERIAL_LOCK=/tmp/corpus-syncthing-git-serial.lock
# CORPUS_SYNCTHING_PAUSE_FLOCK_WAIT_SEC=240
