# Real file: vps/.env (gitignored). Full reference: docs/setup-and-operations.md

DEFAULT_BRANCH=main
COMMIT_MESSAGE_PREFIX=sync
GIT_AUTHOR_NAME="Corpus Bot"
GIT_AUTHOR_EMAIL=corpus-bot@example.com

# Optional: pause Syncthing peers during git (syncthing container uses host network → default URL)
# SYNCTHING_PAUSE_FOR_GIT=1
# SYNCTHING_API_KEY=

# NOTIFY_WEBHOOK_URL=

# Sync webhook secrets (CORPUS_SYNC_WEBHOOK_SECRET / CORPUS_GITHUB_WEBHOOK_SECRET) are
# appended here by `sudo vps/install-sync-webhook.sh` — one-time global setup. Vaults
# under /srv/vaults are auto-discovered, so no per-vault keys live in this file.
